###############################################################################
# Directories
###############################################################################
BINDIR		=	$(ARM_GCCROOT)/bin
STDINC		=	$(ARM_GCCROOT)/arm-elf/include
STDLIB		=	$(ARM_GCCROOT)/arm-elf/lib

ifeq ($(PLATFORM_HOLDER),KTF)

## KTF ł×Ć®żöĹ©
GCSNETWORK_INC	=	$(GCS_ROOT)/include

ifeq ($(PRODUCT_ID),KTF_G1000)
