else
TC_ROOT		=	$(I3_WIPI_SDK_KTF)
GCSNETWORK_LIB	=	$(GCS_ROOT)/lib_Standard/GCSAPI.o
endif

TC_INC		=	$(TC_ROOT)/include_arm
TC_WIPIINC	=	$(TC_ROOT)/include_WIPIC

endif

ifeq ($(PLATFORM_HOLDER),SKT)
TC_ROOT		=	$(I3_WIPI_SDK_SKT)
