<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.10"
	Name="i3Base"
	ProjectGUID="{EA152112-999A-4CB0-B026-8BC793573FEE}"
	SccProjectName="&quot;$/i3&quot;, BAAAAAAA"
	SccAuxPath=""
	SccLocalPath="..\..\.."
	SccProvider="MSSCCI:Microsoft Visual SourceSafe">
	<Platforms>
		<Platform
			Name="Win32"/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="PSP HW Debug|Win32"
			OutputDirectory="PSP_HW_Debug"
			IntermediateDirectory="PSP_HW_Debug"
			ConfigurationType="4"
			DeleteExtensionsOnClean="*.obj;*.d;*.map;*.lst;*.pch;$(TargetPath)">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="-g -O0 --use_pch=&quot;$(IntDir)/$(TargetName).pch&quot;"
				AdditionalIncludeDirectories="$(I3_ROOT)/include;$(I3_ROOT)/include/i3Base"
				PreprocessorDefinitions="SN_TARGET_PSP_HW;I3_PSP;I3G_PSP;I3_COMPILER_PRODG;I3_DEBUG;_DEBUG"
				UsePrecompiledHeader="3"
				PrecompiledHeaderThrough="i3CommonType.h"
				PrecompiledHeaderFile="$(IntDir)/$(TargetName).pch"
				ProgramDataBaseFileName=""
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLibrarianTool"
				AdditionalOptions=""
				AdditionalDependencies=""
				OutputFile="$(OutDir)/$(ProjectName).lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"
				CommandLine="copy &quot;$(OutDir)\$(TargetFileName)&quot; &quot;$(I3_ROOT)\lib\PSP_ProDG\Debug\&quot;"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
		<Configuration
			Name="PSP HW Release|Win32"
			OutputDirectory="PSP_HW_Release"
			IntermediateDirectory="PSP_HW_Release"
			ConfigurationType="4"
			DeleteExtensionsOnClean="*.obj;*.d;*.map;*.lst;*.pch;$(TargetPath)">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="-O3 --use_pch=&quot;$(IntDir)/$(TargetName).pch&quot;"
				AdditionalIncludeDirectories=""
				PreprocessorDefinitions="SN_TARGET_PSP_HW;NDEBUG"
				ProgramDataBaseFileName=""
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLibrarianTool"
				AdditionalOptions=""
				OutputFile="$(OutDir)/$(ProjectName).lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
	</Configurations>
