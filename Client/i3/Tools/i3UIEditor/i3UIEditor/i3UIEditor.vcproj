				AdditionalDependencies="i3BaseDx.lib i3MathDx.lib i3InputDx.lib i3GfxDx.lib i3SceneDx.lib i3SceneUtilDx.lib i3FrameworkDx.lib i3SoundDx.lib i3TDK.lib zlib.lib"
				LinkIncremental="2"
