				Name="VCCLCompilerTool"
				AdditionalOptions="/D &quot;_BIND_TO_CURRENT_MFC_VERSION=1&quot;&#x0D;&#x0A;/D &quot;_BIND_TO_CURRENT_CRT_VERSION=1&quot;"
				Optimization="0"
				AdditionalIncludeDirectories="$(I3_ROOT)/include;&quot;$(I3_ROOT)/PhysX/common/include&quot;;&quot;$(I3_ROOT)/PhysX/SDKs/Physics/include&quot;;&quot;$(I3_ROOT)/PhysX/SDKs/PhysXLoader/include&quot;;&quot;$(I3_ROOT)/PhysX\SDKs/Foundation/include&quot;;&quot;$(I3_ROOT)/PhysX/SDKs/Framework/include&quot;;&quot;$(I3_ROOT)/PhysX/SDKs/Cooking/include&quot;;&quot;$(I3_ROOT)/PhysX/SDKs/NxCharacter/include&quot;;&quot;$(I3_ROOT)/FMOD/fmoddesignerapi/api\inc&quot;;&quot;$(I3_ROOT)/FMOD/api/inc&quot;;&quot;$(I3_ROOT)/PhysX/Tools/NxuStream2&quot;"
				PreprocessorDefinitions="WIN32;_WINDOWS;_DEBUG;I3_COMPILER_VC;I3_DEBUG;I3_WINDOWS;I3_DLL;I3G_DX"
				MinimalRebuild="true"
				BasicRuntimeChecks="3"
				RuntimeLibrary="3"
				StructMemberAlignment="5"
				EnableEnhancedInstructionSet="1"
				TreatWChar_tAsBuiltInType="false"
				UsePrecompiledHeader="2"
				WarningLevel="4"
				Detect64BitPortabilityProblems="false"
				DebugInformationFormat="4"
