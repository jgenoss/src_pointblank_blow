    EDITTEXT        IDC_EDIT_MIPMAP_CY,224,46,44,12,ES_AUTOHSCROLL | ES_NUMBER | WS_DISABLED
    GROUPBOX        "",IDC_STATIC,3,38,293,39
    LTEXT           "MinY",IDC_STATIC,198,47,23,10
    LTEXT           "MinX",IDC_STATIC,106,47,20,11
    EDITTEXT        IDC_EDIT_MAXLEVEL,130,60,45,14,ES_AUTOHSCROLL | WS_DISABLED
