            MENUITEM "Select...",                   ID_SPRING_SELECT
            MENUITEM SEPARATOR
            MENUITEM "Delete",                      ID_SPRING_DELETE
        END
        MENUITEM SEPARATOR
        MENUITEM "Create Cloth...",             ID_VERTEX_CREATECLOTHPARTICLES

    END
END


