IDR_POPUP_VERTEX MENU 
BEGIN
    POPUP "Vertex"
    BEGIN
        MENUITEM "Freeze...",                   ID_VERTEX_FREEZE
        MENUITEM "Texture Mapping",             ID_VERTEX_TEXTUREMAPPING
        MENUITEM "Lighting",                    ID_VERTEX_LIGHTING
        MENUITEM "Backface Culling",            ID_VERTEX_BACKFACECULLING
        POPUP "Render Mode"
        BEGIN
            MENUITEM "Polygon",                     ID_RENDERMODE_POLYGON
            MENUITEM "Line",                        ID_RENDERMODE_LINE
        END
        MENUITEM SEPARATOR
        POPUP "Particle..."
        BEGIN
            MENUITEM "Visible",                     ID_VERTEX_VERTEXVISIBLE
        END
        POPUP "Spring..."
        BEGIN
            MENUITEM "Visible...",                  ID_VERTEX_SPRINGVISIBLE
            MENUITEM SEPARATOR
            MENUITEM "Select All",                  ID_SPRING_SELECTALL
            MENUITEM "Unselect All",                ID_SPRING_UNSELECTALL
