    EDITTEXT        IDC_OPTION_EDIT_WORK,7,20,209,13,ES_AUTOHSCROLL
    LTEXT           "Working Directory",IDC_STATIC,7,7,81,10
    EDITTEXT        IDC_OPTION_EDIT_RSC,14,65,203,13,ES_AUTOHSCROLL
    LTEXT           "RSC Generator",IDC_STATIC,14,54,81,10
    GROUPBOX        "Excute File Setting",IDC_STATIC,7,42,236,90
    PUSHBUTTON      "...",ID_OPTION_BTN_RSC,224,64,19,14
END

IDD_DIALOG_RSC DIALOGEX 0, 0, 262, 174
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CLIPCHILDREN | WS_CAPTION
CAPTION "RSC File Dialog"
