/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDR_MAINFRAME           ICON                    "res\\i3GameEditor.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "파일(&F)"
    BEGIN
        MENUITEM "새로하기(&N)",                ID_FILE_NEW
        MENUITEM "열기(&O)",                    ID_FILE_OPEN
        MENUITEM "저장하기(&S)",                ID_FILE_SAVE
        MENUITEM "다른이름으로 저장하기(&A)",   ID_FILE_SAVE_AS
        MENUITEM "끝내기(&X)",                  ID_APP_EXIT
    END
    POPUP "편집(&E)"
    BEGIN
        MENUITEM "실행 취소\tCtrl+Z(&U)",       ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "잘라내기\tCtrl+X(&T)",        ID_EDIT_CUT
        MENUITEM "복사\tCtrl+C(&C)",            ID_EDIT_COPY
        MENUITEM "붙여넣기\tCtrl+V(&P)",        ID_EDIT_PASTE
    END
    POPUP "설정(&S)"
    BEGIN
        MENUITEM "Option(&O)",                  ID_OPTION
    END
    POPUP "도움말(&H)"
    BEGIN
        MENUITEM "i3GameEditor 정보(&A)...",    ID_APP_ABOUT
    END
END

IDR_POPUP_STAGE MENU 
BEGIN
    POPUP "POPUP_STAGE"
    BEGIN
        MENUITEM "&Add Stage",                  ID_POPUP_ADDSTAGE
        MENUITEM "&Delete Stage",               ID_POPUP_DELETESTAGE
    END
END

IDR_POPUP_LAYER MENU 
BEGIN
    POPUP "POPUP_LAYER"
    BEGIN
        MENUITEM "Add Layer",                   ID_POPUP_ADDLAYER
        MENUITEM "Delete Layer",                ID_POPUP_DELETELAYER
    END
END

IDR_POPUP_INSTANCE MENU 
BEGIN
    POPUP "IDR_POPUP_INSTANCE"
    BEGIN
        MENUITEM "&Add New Instance",           ID_IDR_ADDNEWINSTANCE
        MENUITEM "&Remove Instance",            ID_IDR_REMOVEINSTANCE
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDR_MAINFRAME ACCELERATORS 
BEGIN
    "C",            ID_EDIT_COPY,           VIRTKEY, CONTROL, NOINVERT
    "V",            ID_EDIT_PASTE,          VIRTKEY, CONTROL, NOINVERT
    VK_BACK,        ID_EDIT_UNDO,           VIRTKEY, ALT, NOINVERT
    VK_DELETE,      ID_EDIT_CUT,            VIRTKEY, SHIFT, NOINVERT
    VK_F6,          ID_NEXT_PANE,           VIRTKEY, NOINVERT
    VK_F6,          ID_PREV_PANE,           VIRTKEY, SHIFT, NOINVERT
    VK_INSERT,      ID_EDIT_COPY,           VIRTKEY, CONTROL, NOINVERT
    VK_INSERT,      ID_EDIT_PASTE,          VIRTKEY, SHIFT, NOINVERT
    "X",            ID_EDIT_CUT,            VIRTKEY, CONTROL, NOINVERT
    "Z",            ID_EDIT_UNDO,           VIRTKEY, CONTROL, NOINVERT
END


