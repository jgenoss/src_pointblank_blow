IDD_ABOUTBOX DIALOGEX 0, 0, 235, 55
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "i3GuiOpt 정보"
FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,11,17,20,20
    LTEXT           "i3GuiOpt Version 1.0",IDC_STATIC,40,10,119,8,SS_NOPREFIX
    LTEXT           "Copyright (C) 2010",IDC_STATIC,40,25,119,8
    DEFPUSHBUTTON   "확인",IDOK,178,7,50,16,WS_GROUP
END

IDD_I3GUIOPT_DIALOG DIALOGEX 0, 0, 320, 200
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_VISIBLE | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "확인",IDOK,263,7,50,16
    PUSHBUTTON      "취소",IDCANCEL,263,25,50,16
    CTEXT           "TODO: 여기에 대화 상자 컨트롤을 배치합니다.",IDC_STATIC,10,96,300,8
END

IDD_PANEL_VIEWER DIALOGEX 0, 0, 186, 90
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_SYSMENU
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,129,7,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,129,24,50,14
END

IDD_PANEL_OPT_PALETTE DIALOGEX 0, 0, 186, 90
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_SYSMENU
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    CONTROL         "",IDC_TREE_OPT,"SysTreeView32",WS_HSCROLL | WS_TABSTOP,14,7,60,50,WS_EX_STATICEDGE
END

IDD_PANEL_OPT_SELECTED DIALOGEX 0, 0, 234, 286
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_SYSMENU
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    PUSHBUTTON      "OpenConfig",IDC_BTN_OPEN_CONFIG,8,7,50,14,BS_ICON
    PUSHBUTTON      "SaveConfig",IDC_BTN_SAVE_CONFIG,8,24,50,14,BS_ICON
    PUSHBUTTON      "Select All",IDC_BTN_SELECTALL,64,7,50,14,BS_ICON
    PUSHBUTTON      "Delete",IDC_BTN_DELETE,64,24,50,14,BS_ICON
    PUSHBUTTON      "Run",IDC_BTN_RUN,120,7,45,14,BS_ICON
    PUSHBUTTON      "Stop",IDC_BTN_STOP,120,24,45,14,BS_ICON
    CONTROL         "",IDC_LIST_OPTS,"SysListView32",LVS_REPORT | LVS_OWNERDRAWFIXED | LVS_ALIGNLEFT | WS_TABSTOP,7,44,60,50
END

IDD_PANEL_FILES DIALOGEX 0, 0, 186, 90
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_SYSMENU
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    CONTROL         "",IDC_LIST_FILE,"SysListView32",LVS_REPORT | LVS_ALIGNLEFT | WS_BORDER | WS_TABSTOP,7,26,60,50
    EDITTEXT        IDC_ED_WORKDIR,29,7,143,14,ES_AUTOHSCROLL
    LTEXT           "Path :",IDC_STATIC,7,9,20,8
END

IDD_PANEL_LOG DIALOGEX 0, 0, 186, 90
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_SYSMENU
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
