IDR_POPUP_FILE MENU 
BEGIN
    POPUP "FILE"
    BEGIN
        MENUITEM "Delete",                      ID_FILE_DELETE
        MENUITEM "Select All",                  ID_FILE_SELECTALL
        MENUITEM "Invert Selection",            ID_FILE_INVERTSELECTION
        MENUITEM "Remove non-exist files",      ID_FILE_REMOVEUNEXISTFILES
        MENUITEM SEPARATOR
        MENUITEM "Import file list..",          ID_FILE_IMPORTFILELIST
        MENUITEM "Merge file list...",          ID_FILE_MERGEFILELIST
        MENUITEM "Export file list..",          ID_FILE_EXPORTFILELIST
    END
END

