				Name="VCPreLinkEventTool"
			/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="mfc90d.lib"
				LinkIncremental="1"
				AdditionalLibraryDirectories="../../lib/DirectX/DebugDLL"
			/>
