        MENUITEM "&Delete...",                  ID_TIMEEVENT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Select &All...",              ID_TIMEEVENT_SELECTALL
        MENUITEM "&Unselect All...",            ID_TIMEEVENT_UNSELECTALL
        MENUITEM SEPARATOR
        MENUITEM "TimeEvent Settings...",       ID_TIMEEVENT_TIMEEVENTSETTINGS
    END
END

