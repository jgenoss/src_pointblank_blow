IDR_POPUP_NODE MENU 
BEGIN
    POPUP "NODE"
    BEGIN
        MENUITEM "E&xpand...",                  ID_NODE_EXPAND
        MENUITEM "Collapse...",                 ID_NODE_COLLAPSE
        POPUP "Show..."
        BEGIN
            MENUITEM "&Name",                       ID_SHOW_NAME
            MENUITEM "&Flags",                      ID_SHOW_FLAGS
            MENUITEM "Render Attributes",           ID_SHOW_RENDERATTRIBUTES
        END
        MENUITEM SEPARATOR
        POPUP "Select..."
        BEGIN
            MENUITEM "Select &All\t\tCtrl+A",       ID_NODE_SELECTALL
            MENUITEM "&Unselect All",               ID_NODE_UNSELECTALL
            MENUITEM "Select All &Descendants",     ID_NODE_SELECTALLDESCENDANT
            MENUITEM "Unselect All Des&cendants",   ID_NODE_UNSELECTALLDESCENDANTS
            MENUITEM "Select by &Type",             ID_NODE_SELECTBYTYPE
            MENUITEM "&Reverse selection",          ID_NODE_REVERSESELECTION
        END
        MENUITEM "&Delete\t\tDel",              ID_NODE_DELETE
        MENUITEM SEPARATOR
        POPUP "Node"
        BEGIN
            MENUITEM "Collapse &Node",              ID_NODE_COLLAPSENODE
            MENUITEM "Collapse &Transform",         ID_NODE_COLLAPSETRANSFORM
            MENUITEM "Remove node name from selected items", ID_NODE_REMOVENODENAMES
            MENUITEM "Insert Node...",              ID_NODE_INSERTNODE
        END
        POPUP "Bound Box"
        BEGIN
            MENUITEM "Set BoundBox",                ID_BOUNDBOX_SETBOUNDBOX
            MENUITEM "Remove BoundBox",             ID_NODE_REMOVEBOUNDBOX
            MENUITEM "Visible BoundBox",            ID_BOUNDBOX_VISIBLEBOUNDBOX
        END
        POPUP "Attribute"
        BEGIN
            MENUITEM "Insert Attributes...",        ID_ATTRIBUTE_INSERTATTRIBUTES
            MENUITEM "Remove Attribute from Descendents", ID_ATTRIBUTE_REMOVEATTRIBUTEFROMDESCENDENTS
        END
        MENUITEM SEPARATOR
        MENUITEM "Import Scene-Graph",          ID_NODE_IMPORTSCENE
        MENUITEM "Export Scene-Graph",          ID_NODE_EXPORTSCENE
        MENUITEM SEPARATOR
    END
END

IDR_POPUP_TIMESEQ MENU 
BEGIN
    POPUP "TIMESEQCTRL"
    BEGIN
        MENUITEM "Rename",                      ID_TIMESEQCTRL_RENAME
        MENUITEM "Select &All",                 ID_TIMESEQCTRL_SELECTALL
        MENUITEM "&Unselect All",               ID_TIMESEQCTRL_UNSELECTALL
        MENUITEM "Copy...",                     ID_TIMESEQCTRL_COPY
        MENUITEM "Paste...",                    ID_TIMESEQCTRL_PASTE
        MENUITEM "&Delete...",                  ID_TIMESEQCTRL_DELETE
        MENUITEM SEPARATOR
    END
END

IDR_POPUP_TIMEEVENT MENU 
