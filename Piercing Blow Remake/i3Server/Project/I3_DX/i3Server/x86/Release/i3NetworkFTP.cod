; 177  : BOOL i3NetworkFTP::DownLoadFile2( char * pszPath )
; 178  : {
; 179  : 	char	szNewFileName[ MAX_PATH ];
; 180  : 
; 181  : 	char	buf[1024];
; 182  : 	BOOL	bResult;
; 183  : 	char	szTemp[4096];
; 184  : 
; 185  : 	DWORD	dwRead;
; 186  : 	i3FileStream	file;
; 187  : 	HINTERNET	hRemote;
; 188  : 
; 189  : 	I3ASSERT( pszPath );
; 190  : 	I3ASSERT( m_hFtp );
; 191  : 
; 192  : 	// open server file
; 193  : 	hRemote = ::FtpOpenFile( m_hFtp, pszPath, GENERIC_READ, FTP_TRANSFER_TYPE_BINARY, 0 );
; 194  : 	if( hRemote == NULL )
; 195  : 	{
; 196  : 		I3TRACE( "i3NetworkFTP::DownLoadFile2() - can't ftp open file.\n" );
; 197  : 		return FALSE;
; 198  : 	}
; 199  : 
; 200  : 	// create local file
; 201  : 	::GetCurrentDirectory( MAX_PATH, szNewFileName );
; 202  : 	strcat( szNewFileName, "\\" );
; 203  : 	strcat( szNewFileName, pszPath );
; 204  : 	
; 205  : 	if( FALSE == file.Create( szNewFileName, STREAM_WRITE ) )
; 206  : 	{
; 207  : 		::InternetCloseHandle( hRemote );
; 208  : 		I3TRACE( "i3NetworkFTP::DownLoadFile2() - can't open file.\n" );
; 209  : 		return FALSE;
; 210  : 	}
; 211  : 
; 212  : 	m_dwProg = 0;
; 213  : 
; 214  : 	for( ;; )
; 215  : 	{
; 216  : 		bResult = ::InternetReadFile( hRemote, buf, 1024, &dwRead );
; 217  : 		if( bResult == TRUE && dwRead == 0 )
; 218  : 			break;
; 219  : 
; 220  : 		file.Printf( szTemp, buf );
; 221  : 		m_dwProg += dwRead;
; 222  : 
; 223  : 		wsprintf( m_szStr, "%s %d", pszPath, m_dwProg);
; 224  : 	}
; 225  : 
; 226  : 	file.Close();
; 227  : 
; 228  : 	::InternetCloseHandle( hRemote );
; 229  : 	return TRUE;
; 230  : }
