; 303  : BOOL i3NetworkFTP::UploadFile2( const char * pszLocalPath, const char * pszRemotePath )
; 304  : {
; 305  : 	HINTERNET	hRemote;
; 306  : 	char	szExt[ _MAX_PATH ];
; 307  : 	char	szRemote[ MAX_PATH ];
; 308  : 	DWORD	dwWritten;
; 309  : 	UINT32	nread;
; 310  : 	UINT32	Rc;
; 311  : 
; 312  : 	char	buf[1024];
; 313  : 
; 314  : 	i3FileStream	stream;
; 315  : 
; 316  : 	I3ASSERT( m_hFtp );
; 317  : 	
; 318  : 	_splitpath( pszRemotePath, NULL, NULL, szRemote, szExt );
; 319  : 	strcat( szRemote, szExt );
; 320  : 
; 321  : 	hRemote = ::FtpOpenFile( m_hFtp, szRemote, GENERIC_WRITE, FTP_TRANSFER_TYPE_BINARY, 0 );
; 322  : 	if( hRemote == NULL )
; 323  : 	{	
; 324  : 		I3TRACE( "i3NetworkFTP::UploadFile2() - %d\n", ::GetLastError() );
; 325  : 
; 326  : 		return FALSE;
; 327  : 	}
; 328  : 	
; 329  : 	if( !stream.Open( pszLocalPath, STREAM_READ | STREAM_SHAREREAD ) )
; 330  : 	{
; 331  : 		I3TRACE( "i3NetworkFTP::UploadFile2() - can't local file open.\n" );
; 332  : 		return FALSE;
; 333  : 	}
; 334  : 
; 335  : 	nread = 1024;
; 336  : 
; 337  : 	for( m_dwProg = 0; m_dwProg < stream.GetSize(); )
; 338  : 	{
; 339  : 		stream.SetPosition( m_dwProg, STREAM_BEGIN );
; 340  : 
; 341  : 		nread = stream.GetSize() - m_dwProg;
; 342  : 
; 343  : 		if( nread > 1024 )
; 344  : 			nread = 1024;
; 345  : 
; 346  : 		Rc = stream.Read( buf, nread );
; 347  : 		if( Rc == STREAM_ERR )
; 348  : 			break;
; 349  : 
; 350  : 		::InternetWriteFile( hRemote, buf, nread, &dwWritten );
; 351  : 		m_dwProg += dwWritten;
; 352  : 
; 353  : 		wsprintf( m_szStr, "%s %d", pszLocalPath, m_dwProg);
; 354  : 	}
; 355  : 
; 356  : 	stream.Close();
; 357  : 
; 358  : 	::InternetCloseHandle( hRemote );
; 359  : 	return TRUE;
; 360  : }
; 361  : 
; 362  : BOOL i3NetworkFTP::CheckFile( const char * pszPath )
; 363  : {
; 364  : 	HINTERNET hSrch;
; 365  : 	WIN32_FIND_DATA wfd;
; 366  : 
; 367  : 	char	szRemotePath[ MAX_PATH ];
; 368  : 	DWORD	dwCDir = MAX_PATH;
; 369  : 
; 370  : 	I3ASSERT( m_hFtp );
; 371  : 
; 372  : 	if( !(getFlags() & I3_FTP_FLAG_CONNECTMAINTAIN) )
; 373  : 	{
; 374  : 		if( !Connect() )
; 375  : 			return FALSE;
; 376  : 	}
; 377  : 
; 378  : 	memset( szRemotePath, 0, sizeof( szRemotePath ) );
; 379  : 	::FtpGetCurrentDirectory( m_hFtp, szRemotePath, &dwCDir );
; 380  : 	
; 381  : 	strcat( szRemotePath, pszPath );
; 382  : 
; 383  : 	hSrch = ::FtpFindFirstFile( m_hFtp, pszPath, &wfd, 0, 0 );
; 384  : 	if( hSrch == 0 )
; 385  : 	{
; 386  : 		return FALSE;
; 387  : 	}
; 388  : 
; 389  : 	::InternetCloseHandle( hSrch );
; 390  : 
; 391  : 	if( !(getFlags() & I3_FTP_FLAG_CONNECTMAINTAIN ) )
; 392  : 		DisConnect();
; 393  : 
; 394  : 	return TRUE;
; 395  : }
; 396  : 
; 397  : BOOL i3NetworkFTP::DeleteFile( const char * pszPath )
