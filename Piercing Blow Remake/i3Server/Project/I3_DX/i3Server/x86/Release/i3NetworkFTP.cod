; 292  : BOOL i3NetworkFTP::UploadFile2( const char * pszPath )
; 293  : {
; 294  : 	char	szExt[ _MAX_PATH ];
; 295  : 	char	szRemote[ MAX_PATH ];
; 296  : 
; 297  : 	_splitpath( pszPath, NULL, NULL, szRemote, szExt );
