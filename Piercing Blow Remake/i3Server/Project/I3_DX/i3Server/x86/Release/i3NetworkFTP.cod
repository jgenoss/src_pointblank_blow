; 135  : BOOL i3NetworkFTP::DownLoadFile( char * pszLocalPath, char * pszRemotePath )
; 136  : {
; 137  : 	BOOL	bResult = FALSE;
; 138  : 	char	szPath[ MAX_PATH ];
; 139  : 	char	szFileName[ MAX_PATH ];
; 140  : 	char	szExt[ _MAX_PATH ];
; 141  : 	
; 142  : 	char	szFilePath[ MAX_PATH ];
; 143  : 	INT32	nLocalLen, nFileLen;
; 144  : 	
; 145  : 	_splitpath( pszLocalPath, NULL, szPath, szFileName, szExt );
; 146  : 	strcat( szFileName, szExt );
; 147  : 
; 148  : 	nLocalLen = i3String::Length( pszLocalPath );
; 149  : 	nFileLen = i3String::Length( szFileName );
; 150  : 
; 151  : 	nLocalLen -= nFileLen;
; 152  : 
; 153  : 	strcpy( szFilePath, m_szLocalDirectory );
; 154  : 	strcat( szFilePath, "\\" );
; 155  : 
; 156  : 	if( nLocalLen > 0 )
; 157  : 	{
; 158  : 		strcat( szFilePath, szPath );
; 159  : 
; 160  : 		CheckDirectory( szFilePath );
; 161  : 	}
; 162  : 
; 163  : 	// ąŢŔ» µđ·şĹä¸®·Î ĽĽĆĂ
; 164  : 	::SetCurrentDirectory( szFilePath );
; 165  : 
; 166  : 	sprintf( m_szStr, "Download : %s\n ", pszLocalPath );
; 167  : 
; 168  : 	bResult = ::FtpGetFile( m_hFtp, pszRemotePath, szFileName, FALSE, FILE_ATTRIBUTE_NORMAL,
; 169  : 		FTP_TRANSFER_TYPE_BINARY | INTERNET_FLAG_RELOAD, 0 );
; 170  : 
; 171  : 	// ·çĆ® µđ·şĹä¸®·Î µą·Áłő´Â´Ů.
; 172  : 	::SetCurrentDirectory( m_szLocalDirectory );
; 173  : 
; 174  : 	return bResult;
; 175  : }
