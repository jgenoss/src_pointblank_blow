; 995  : bool TiXmlDocument::LoadFile( const char* _filename, TiXmlEncoding encoding )
; 996  : {
; 997  : 	// There was a really terrifying little bug here. The code:
; 998  : 	//		value = filename
; 999  : 	// in the STL case, cause the assignment method of the std::string to
; 1000 : 	// be called. What is strange, is that the std::string had the same
; 1001 : 	// address as it's c_str() method, and so bad things happen. Looks
; 1002 : 	// like a bug in the Microsoft STL implementation.
; 1003 : 	// Add an extra string to avoid the crash.
; 1004 : 	TIXML_STRING filename( _filename );
; 1005 : 	value = filename;
; 1006 : 
; 1007 : 	// reading in binary mode so that tinyxml can normalize the EOL
; 1008 : 	i3FileStream* file = TiXmlFOpen( value.c_str (), STREAM_READ | STREAM_WRITE);	
; 1009 : 
; 1010 : 	if ( file )
; 1011 : 	{
; 1012 : 		bool result = LoadFile( file, encoding );
; 1013 : 		
; 1014 : 		//	Ăß°ˇ komet
; 1015 : 		fileSize = file->GetSize();
; 1016 : 
; 1017 : 		file->Close();
; 1018 : 
; 1019 : 		I3_SAFE_RELEASE(file);
; 1020 : 
; 1021 : 		return result;
; 1022 : 	}
; 1023 : 	else
; 1024 : 	{
; 1025 : 		SetError( TIXML_ERROR_OPENING_FILE, 0, 0, TIXML_ENCODING_UNKNOWN );
; 1026 : 		return false;
; 1027 : 	}
; 1028 : }
; 1029 : 
; 1030 : bool TiXmlDocument::LoadFile( i3FileStream* file, TiXmlEncoding encoding )
; 1031 : {
; 1032 : 	if ( !file ) 
; 1033 : 	{
; 1034 : 		SetError( TIXML_ERROR_OPENING_FILE, 0, 0, TIXML_ENCODING_UNKNOWN );
; 1035 : 		return false;
; 1036 : 	}
; 1037 : 
; 1038 : 	// Delete the existing data:
; 1039 : 	Clear();
; 1040 : 	location.Clear();
; 1041 : 
; 1042 : 	// Get the file size, so we can pre-allocate the string. HUGE speed impact.
; 1043 : 	long length = 0;
; 1044 : 	length = (long)file->GetSize();
; 1045 : 	//fseek( file, 0, SEEK_END );
; 1046 : 	//length = ftell( file );
; 1047 : 	//fseek( file, 0, SEEK_SET );
; 1048 : 
; 1049 : 	// Strange case, but good to handle up front.
; 1050 : 	if ( length <= 0 )
; 1051 : 	{
; 1052 : 		SetError( TIXML_ERROR_DOCUMENT_EMPTY, 0, 0, TIXML_ENCODING_UNKNOWN );
; 1053 : 		return false;
; 1054 : 	}
; 1055 : 
; 1056 : 	// If we have a file, assume it is all one big XML file, and read it in.
; 1057 : 	// The document parser may decide the document ends sooner than the entire file, however.
; 1058 : 	TIXML_STRING data;
; 1059 : 	data.reserve( length );
; 1060 : 
; 1061 : 	// Subtle bug here. TinyXml did use fgets. But from the XML spec:
; 1062 : 	// 2.11 End-of-Line Handling
; 1063 : 	// <snip>
; 1064 : 	// <quote>
; 1065 : 	// ...the XML processor MUST behave as if it normalized all line breaks in external 
; 1066 : 	// parsed entities (including the document entity) on input, before parsing, by translating 
; 1067 : 	// both the two-character sequence #xD #xA and any #xD that is not followed by #xA to 
; 1068 : 	// a single #xA character.
; 1069 : 	// </quote>
; 1070 : 	//
; 1071 : 	// It is not clear fgets does that, and certainly isn't clear it works cross platform. 
; 1072 : 	// Generally, you expect fgets to translate from the convention of the OS to the c/unix
; 1073 : 	// convention, and not work generally.
; 1074 : 
; 1075 : 	/*
; 1076 : 	while( fgets( buf, sizeof(buf), file ) )
; 1077 : 	{
; 1078 : 		data += buf;
; 1079 : 	}
; 1080 : 	*/
; 1081 : 
; 1082 : 	char* buf = new char[ length+1 ];
; 1083 : 	buf[0] = 0;
; 1084 : 	
; 1085 : 	//if ( fread( buf, length, 1, file ) != 1 ) {
; 1086 : 	if(file->Read(buf, length) == STREAM_ERR) {
; 1087 : 		delete [] buf;
; 1088 : 		SetError( TIXML_ERROR_OPENING_FILE, 0, 0, TIXML_ENCODING_UNKNOWN );
; 1089 : 		return false;
; 1090 : 	}
; 1091 : 
; 1092 : 	const char* lastPos = buf;
; 1093 : 	const char* p = buf;
; 1094 : 
; 1095 : 	buf[length] = 0;
; 1096 : 	while( *p ) {
; 1097 : 		I3ASSERT( p < (buf+length) );
; 1098 : 		if ( *p == 0xa ) {
; 1099 : 			// Newline character. No special rules for this. Append all the characters
; 1100 : 			// since the last string, and include the newline.
; 1101 : 			data.append( lastPos, (p-lastPos+1) );	// append, include the newline
; 1102 : 			++p;									// move past the newline
; 1103 : 			lastPos = p;							// and point to the new buffer (may be 0)
; 1104 : 			I3ASSERT( p <= (buf+length) );
; 1105 : 		}
; 1106 : 		else if ( *p == 0xd ) {
; 1107 : 			// Carriage return. Append what we have so far, then
; 1108 : 			// handle moving forward in the buffer.
; 1109 : 			if ( (p-lastPos) > 0 ) {
; 1110 : 				data.append( lastPos, p-lastPos );	// do not add the CR
; 1111 : 			}
; 1112 : 			data += (char)0xa;						// a proper newline
; 1113 : 
; 1114 : 			if ( *(p+1) == 0xa ) {
; 1115 : 				// Carriage return - new line sequence
; 1116 : 				p += 2;
; 1117 : 				lastPos = p;
; 1118 : 				I3ASSERT( p <= (buf+length) );
; 1119 : 			}
; 1120 : 			else {
; 1121 : 				// it was followed by something else...that is presumably characters again.
; 1122 : 				++p;
; 1123 : 				lastPos = p;
; 1124 : 				I3ASSERT( p <= (buf+length) );
; 1125 : 			}
; 1126 : 		}
; 1127 : 		else {
; 1128 : 			++p;
; 1129 : 		}
; 1130 : 	}
; 1131 : 	// Handle any left over characters.
; 1132 : 	if ( p-lastPos ) {
; 1133 : 		data.append( lastPos, p-lastPos );
; 1134 : 	}		
; 1135 : 	delete [] buf;
; 1136 : 	buf = 0;
; 1137 : 
; 1138 : 	Parse( data.c_str(), 0, encoding );
; 1139 : 
; 1140 : 	if (  Error() )
; 1141 :         return false;
; 1142 :     else
; 1143 : 		return true;
; 1144 : }
; 1145 : 
