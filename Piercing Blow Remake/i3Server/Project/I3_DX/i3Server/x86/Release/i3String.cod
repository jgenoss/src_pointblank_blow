; 2528 : I3_EXPORT_BASE
; 2529 : const char * i3String::CharNext(INT32 nCodePage, const char * pszStr)
; 2530 : {
; 2531 : 	I3ASSERT( pszStr != NULL && nCodePage != 0 && nCodePage != 1);
; 2532 : 
; 2533 : 	switch( nCodePage)
; 2534 : 	{
; 2535 : 	case I3_LANG_CODE_THAI:		//	THAI			ĹÂ±ąŔş Á¶ÇŐÇü MBCS ĂĽ°č (1~4ąŮŔĚĆ® °ˇşŻ ąŮŔĚĆ® ) ÁÖŔÇ! ĹÂ±ąľî´Â 2ąŮŔĚĆ®°ˇ ľĆ´Ď´Ů!
; 2536 : 		{
