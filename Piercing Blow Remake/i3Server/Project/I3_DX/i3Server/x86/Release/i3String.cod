; 1602 : // UCS2 -> UTF8 encode
; 1603 : //
; 1604 : // UTF-8·Î şŻČŻµČ ł»żëŔ» ĆÄŔĎ·Î ŔúŔĺÇŇ·Á¸é, ÇŘ´ő·Î 3ąŮŔĚĆ®¸¦ ˝á ÁÖľîľß µĘ.
; 1605 : // 0xEF 0xBB 0xBF
; 1606 : // 
; 1607 : int i3String::UCS2toUTF8( char *pDest, const WCHAR16 *pSrc, int nDestBufSize )
; 1608 : {
; 1609 : 	if( pSrc == NULL ) return 0;
; 1610 : 
; 1611 : 	int count = (int)( i3String::Length( pSrc ) );
; 1612 : 	WCHAR16 unicode;
; 1613 : 	unsigned char bytes[4];
; 1614 : 	int nbytes;
; 1615 : 	int len = 0;
; 1616 : 
; 1617 : 	for( int i = 0; i < count; i++ )
; 1618 : 	{
; 1619 : 		unicode = pSrc[i];
; 1620 : 		if ( unicode < 0x80 )
; 1621 : 		{
; 1622 : 			nbytes = 1;
; 1623 : 			bytes[0] = (unsigned char) unicode;							//  0xxxxxxx
; 1624 : 		}
; 1625 : 		else if ( unicode < 0x0800 )
; 1626 : 		{
; 1627 : 			nbytes = 2;
; 1628 : 			bytes[1] = (unsigned char) ((unicode & 0x3f) | 0x80);		// 10xxxxxx
; 1629 : 			bytes[0] = (unsigned char) ((unicode >> 6) & 0x1f | 0xc0) ;	// 110xxxxx
; 1630 : 		}
; 1631 : 		else
; 1632 : 		{
; 1633 : 			nbytes = 3;
; 1634 : 			bytes[2] = (unsigned char) ((unicode & 0x3f) | 0x80);		// 10xxxxxx
; 1635 : 			bytes[1] = (unsigned char) ((unicode >> 6) & 0x3f | 0x80);	// 10xxxxxx
; 1636 : 			bytes[0] = (unsigned char) ((unicode >> 12) & 0x0f | 0xe0);	// 1110xxxx
; 1637 : 		}
; 1638 : 
; 1639 : 		if( (len + nbytes) >= nDestBufSize )
; 1640 : 		{
; 1641 : 			I3WARN("Need more buffer size.\n");
; 1642 : 			//I3TRACE( "[%s] : Need more buffer size.\n", __FUNCTION__ );
; 1643 : 			I3ASSERT_0;
; 1644 : 			break;
; 1645 : 		}
; 1646 : 
; 1647 : 		for( int j = 0; j < nbytes; j++ )
; 1648 : 		{
; 1649 : 			pDest[len] = bytes[j];
; 1650 : 			len++;
; 1651 : 		}
; 1652 : 	}
; 1653 : 
; 1654 : 	pDest[len] = 0x00;
; 1655 : 
; 1656 : 	return len;
; 1657 : }
; 1658 : 
; 1659 : // UTF-8Ć÷¸ËŔ» ŔŻ´ĎÄÚµĺ ˝şĆ®¸µŔ¸·Î µđÄÚµů
; 1660 : //
; 1661 : // UTF-8·Î şŻČŻµČ ł»żëŔ» ĆÄŔĎ·Î ŔúŔĺÇŇ·Á¸é, ÇŘ´őżˇ ´ŮŔ˝ŔÇ 2ąŮŔĚĆ®¸¦ ˝á ÁÖľîľß µĘ.
; 1662 : // 0xFF 0xFE
; 1663 : //
; 1664 : int i3String::UTF8toUCS2( WCHAR16 *pDest, const char *_pSrc, int nDestBufSize )
; 1665 : {
; 1666 : 	unsigned char *pSrc = ( unsigned char * )_pSrc;
; 1667 : 	unsigned char c;
; 1668 : 	WCHAR16 unicode;
; 1669 : 	int count = 0;
; 1670 : 	int i = 0;
; 1671 : 	//int len = Length( pSrc );
; 1672 : 	int len = (int)strlen( _pSrc );
; 1673 : 
; 1674 : 	for( i = 0; i < len; )
; 1675 : 	{
; 1676 : 		if( ( count + 1 ) >= nDestBufSize )
; 1677 : 		{
; 1678 : 			I3WARN("Need more buffer size.\n");
; 1679 : 			//I3TRACE( "[%s] : Need more buffer size.\n", __FUNCTION__ );
; 1680 : 			I3ASSERT_0;
; 1681 : 			break;
; 1682 : 		}
; 1683 : 
; 1684 : 		c = pSrc[i] & 0xe0;
; 1685 : 
; 1686 : 		if( c < 0x80 )
; 1687 : 		{
; 1688 : 			unicode = WCHAR16( pSrc[i] );
; 1689 : 			i++;
; 1690 : 		}
; 1691 : 		else if ( c < 0xe0 )
; 1692 : 		{
; 1693 : 			unicode =	WCHAR16( pSrc[i] & 0x1f );
; 1694 : 			i++;
; 1695 : 			unicode =	unicode << 6;
; 1696 : 			unicode |=	WCHAR16( pSrc[i] & 0x3f );
; 1697 : 			i++;
; 1698 : 		}
; 1699 : 		else if ( c < 0xf0 )
; 1700 : 		{
; 1701 : 			unicode =	WCHAR16( pSrc[i] & 0x0f );
; 1702 : 			i++;
; 1703 : 			unicode =	unicode << 6;
; 1704 : 			unicode |=	WCHAR16( pSrc[i] & 0x3f );
; 1705 : 			i++;
; 1706 : 			unicode =	unicode << 6;
; 1707 : 			unicode |=	WCHAR16( pSrc[i] & 0x3f );
; 1708 : 			i++;
; 1709 : 		}
; 1710 : 		else
; 1711 : 		{
; 1712 : 			I3WARN("Invalid character.\n");
; 1713 : 			//I3TRACE( "[%s] : Invalid character.\n", __FUNCTION__ );
; 1714 : 			I3ASSERT_0;
; 1715 : 			break;
; 1716 : 		}
; 1717 : 
; 1718 : 		pDest[count] = unicode;
; 1719 : 		count++;
; 1720 : 	}
; 1721 : 
; 1722 : 	pDest[count] = 0x0000;
; 1723 : 
; 1724 : 	return count;
; 1725 : }
