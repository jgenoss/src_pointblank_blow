; 1789 : void i3String::ResolvePathToken( const char * pszPath, i3StringList * pList)
; 1790 : {
; 1791 : 	char * pTemp;
; 1792 : 	char szBuf[MAX_PATH];
; 1793 : 	INT32 i;
; 1794 : 
; 1795 : 	for( i = 0, pTemp = (char *) pszPath; *pTemp != 0; pTemp++)
; 1796 : 	{
; 1797 : 		if( *pTemp & 0x80)
; 1798 : 		{
; 1799 : 			szBuf[i] = *pTemp;
; 1800 : 			i++;
; 1801 : 			pTemp ++;
; 1802 : 		}
; 1803 : 		else
; 1804 : 		{
; 1805 : 			if((*pTemp == '\\') || (*pTemp == '/'))
; 1806 : 			{
; 1807 : 				szBuf[i] = 0;
; 1808 : 				pList->Add( szBuf);
; 1809 : 				
; 1810 : 				i = 0;
; 1811 : 				continue;
; 1812 : 			}
; 1813 : 		}
; 1814 : 
; 1815 : 		szBuf[i] = *pTemp;
; 1816 : 		i++;
; 1817 : 	}
; 1818 : 
; 1819 : 	if( i > 0)
; 1820 : 	{
; 1821 : 		szBuf[i] = 0;
; 1822 : 		pList->Add( szBuf);
; 1823 : 	}
; 1824 : }
; 1825 : 
; 1826 : void i3String::MakeRelativePath( const char * pszBasePath, const char * pszAbsPath, char * pszRelPath, const INT32 nRelPathMax)
; 1827 : {
; 1828 : 	i3StringList BaseToken, AbsToken;
; 1829 : 	char * pszBase, *pszAbs;
; 1830 : 	INT32 sidx, didx;
; 1831 : 	bool bProcess, bDiff = false;
; 1832 : 
; 1833 : 	ResolvePathToken( pszBasePath, &BaseToken);
; 1834 : 	ResolvePathToken( pszAbsPath, &AbsToken);
; 1835 : 
; 1836 : 	if( BaseToken.GetCount() <= 0)
; 1837 : 	{
; 1838 : 		i3String::Copy( pszRelPath, pszAbsPath, nRelPathMax);
; 1839 : 		return;
; 1840 : 	}
; 1841 : 
; 1842 : 	if( AbsToken.GetCount() <= 0)
; 1843 : 		return;
; 1844 : 
; 1845 : 	#if defined( I3_WINDOWS)
; 1846 : 		// Drive ¸íŔ» żěĽ± Č®ŔÎÇŃ´Ů.
; 1847 : 		// ¸¸ľŕ ´Ů¸Ą Drive¶ó¸é ľĆą«·± Ăł¸® ľřŔĚ ±×łÉ Relative Pathżˇ ŔúŔĺÇĎ°í
; 1848 : 		// ąÝČŻÇŃ´Ů.
; 1849 : 		if( i3String::Compare( BaseToken.Items[0], AbsToken.Items[0]) != 0)
; 1850 : 		{
; 1851 : 			i3String::Copy( pszRelPath, pszAbsPath, nRelPathMax);
; 1852 : 			return;
; 1853 : 		}
; 1854 : 	#endif
; 1855 : 
; 1856 : 	sidx = 0;
; 1857 : 	didx = 0;
; 1858 : 	pszRelPath[0] = 0;
; 1859 : 
; 1860 : 	while( didx < AbsToken.GetCount())
; 1861 : 	{
; 1862 : 		bProcess = true;
; 1863 : 
; 1864 : 		pszAbs = AbsToken.Items[didx];
; 1865 : 
; 1866 : 		if( sidx < BaseToken.GetCount())
; 1867 : 		{
; 1868 : 			pszBase = BaseToken.Items[sidx];
; 1869 : 
; 1870 : 			if( (bDiff == false) && (i3String::Compare( pszBase, pszAbs) == 0))
; 1871 : 			{
; 1872 : 				bProcess = false;
; 1873 : 				didx++;
; 1874 : 			}
; 1875 : 			else
; 1876 : 			{
; 1877 : 				pszAbs = "..";
; 1878 : 				bDiff = true;
; 1879 : 			}
; 1880 : 
; 1881 : 			sidx++;
; 1882 : 		}
; 1883 : 		else
; 1884 : 		{
; 1885 : 			didx++;
; 1886 : 		}
; 1887 : 
; 1888 : 		if( bProcess)
; 1889 : 		{
; 1890 : 			i3String::Concat( pszRelPath, pszAbs);
; 1891 : 
; 1892 : 			if( didx < AbsToken.GetCount())
; 1893 : 				i3String::Concat( pszRelPath, "\\");
; 1894 : 		}
; 1895 : 	}
; 1896 : }
; 1897 : 
; 1898 : void i3String::MakeCStylePath( char * pszDest, const char * pszSrc)
; 1899 : {
; 1900 : 	I3ASSERT( pszDest != NULL);
; 1901 : 	I3ASSERT( pszSrc != NULL);
; 1902 : 
; 1903 : 	while( *pszSrc != 0)
; 1904 : 	{
; 1905 : 		*pszDest = *pszSrc;
; 1906 : 
; 1907 : 		if( *pszSrc == '\\')
; 1908 : 		{
; 1909 : 			pszDest++;
; 1910 : 			*pszDest = '\\';
; 1911 : 		}
; 1912 : 
; 1913 : 		pszDest++;
; 1914 : 		pszSrc++;
; 1915 : 	}
; 1916 : 
; 1917 : 	*pszDest = 0;
; 1918 : }
; 1919 : 
; 1920 : enum ATOI_MODE
; 1921 : {
; 1922 : 	ATOI_DECIMAL = 0,
; 1923 : 	ATOI_HEXA,
; 1924 : };
; 1925 : 
; 1926 : INT32 i3String::ToInt( const char * pszStr)
; 1927 : {
; 1928 : 	ATOI_MODE mode = ATOI_DECIMAL;
; 1929 : 	INT32 rv = 0, sign = 1;
; 1930 : 	char ch;
; 1931 : 
; 1932 : 	if((pszStr[0] == '0') && ((pszStr[1] == 'x') || (pszStr[1] == 'X')))
; 1933 : 	{
; 1934 : 		mode = ATOI_HEXA;
; 1935 : 		pszStr += 2;
; 1936 : 	}
; 1937 : 
; 1938 : 	while( * pszStr)
; 1939 : 	{
; 1940 : 		switch( *pszStr)
; 1941 : 		{
; 1942 : 			case '-' :	sign = -1;	break;
; 1943 : 			case '+' :				break;
; 1944 : 			default :
; 1945 : 
; 1946 : 				if( mode == ATOI_DECIMAL)
; 1947 : 				{
; 1948 : 					if( (*pszStr >= '0') && (*pszStr <= '9'))
; 1949 : 					{
; 1950 : 						rv *= 10;
; 1951 : 						rv += *pszStr - '0';
; 1952 : 					}
; 1953 : 					else
; 1954 : 						return 0;
; 1955 : 				}
; 1956 : 				else
; 1957 : 				{
; 1958 : 					rv <<= 4;
; 1959 : 
; 1960 : 					if( (*pszStr >= '0') && (*pszStr <= '9'))
; 1961 : 					{
; 1962 : 						rv += *pszStr - '0';
; 1963 : 					}
; 1964 : 					else 
; 1965 : 					{
; 1966 : 						if( (*pszStr >= 'a') && (*pszStr <= 'f'))
; 1967 : 							ch = *pszStr - 'a';
; 1968 : 						else if((*pszStr >= 'A') && (*pszStr <= 'F'))
; 1969 : 							ch = *pszStr - 'A';
; 1970 : 						else
; 1971 : 							return 0;
; 1972 : 
; 1973 : 						rv += ch + 10;
; 1974 : 					}
; 1975 : 				}
; 1976 : 				break;
; 1977 : 		}
; 1978 : 
; 1979 : 		pszStr++;
; 1980 : 	}
; 1981 : 
; 1982 : 	return rv * sign;
; 1983 : }
; 1984 : 
; 1985 : static I3_SYMBOLTABLE_INFO *	_FindSymbol( I3_SYMBOLTABLE_INFO * pTable, INT32 symbolCount, char * pszStr)
; 1986 : {
; 1987 : 	INT32 i;
; 1988 : 
; 1989 : 	for( i = 0; i < symbolCount; i++)
; 1990 : 	{
; 1991 : 		if( i3String::Compare( pTable[i].m_szSymbol, pszStr) == 0)
; 1992 : 		{
; 1993 : 			return & pTable[i];
; 1994 : 		}
; 1995 : 	}
; 1996 : 
; 1997 : 	return NULL;
; 1998 : }
