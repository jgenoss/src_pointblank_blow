; 2374 : 
; 2375 : /////////////////////////////////////////////////////////////////////////////////////////////
; 2376 : //	THAI language -- ĽŇ˝ş´Â gpgstudyżˇĽ­ °ˇÁ®żČ (2008.7.31 komet)
; 2377 : /////////////////////////////////////////////////////////////////////////////////////////////
; 2378 : 
; 2379 : // Unicode of thai : 0x0E00~0x0E7F (Direct Mapping)
; 2380 : // Thai Character -> Unicode    (char+0x0E00)-0xA0 =    char+0x0D60
; 2381 : // Unicode -> Thai Character (wchar_t-0x0E00)+0xA0 = wchar_t-0x0D60
; 2382 : 
; 2383 : enum THAI_CLASS		//	Thai character classification
; 2384 : {	
; 2385 : 	CTRL= 0,		//	Control characters
; 2386 : 	NON= 1,			//	Non-composibles
; 2387 : 	CONS= 2,		//	Consonants
; 2388 : 	LV= 3,			//	Leading Vowels
; 2389 : 	FV1= 4,			//	Following Vowels
; 2390 : 	FV2= 5,
; 2391 : 	FV3= 6,
; 2392 : 	BV1= 7,			//	Below Vowels
; 2393 : 	BV2= 8,
; 2394 : 	BD= 9,			//	Below Diacritic
; 2395 : 	TONE=10,		//	Tonemarks
; 2396 : 	AD1=11,			//	Above Diacritics
; 2397 : 	AD2=12,
; 2398 : 	AD3=13,
; 2399 : 	AV1=14,			//	Above Vowels
; 2400 : 	AV2=15,
; 2401 : 	AV3=16,
; 2402 : };
; 2403 : 
; 2404 : THAI_CLASS 
; 2405 : THAI_CLASS_TABLE[256] = 
; 2406 : {
; 2407 : 	CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, 
; 2408 : 	CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, 
; 2409 : 	NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON, 
; 2410 : 	NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON, 
; 2411 : 	NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON, 
; 2412 : 	NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON, 
; 2413 : 	NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON, 
; 2414 : 	NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON,  NON, CTRL, 
; 2415 : 	CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, 
; 2416 : 	CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, CTRL, 
