; 2545 : 				I3ASSERT( c2 >= 0 && c2 < 17);
; 2546 : 
; 2547 : 				if( THAI_OUTPUT_STATE_CHECK[c1][c2] == OC)
; 2548 : 					++stream;
; 2549 : 				else
; 2550 : 					break;
; 2551 : 			}
; 2552 : 
; 2553 : 			return (const char*)(stream+1);
; 2554 : 		}
; 2555 : 		break;
; 2556 : 	case I3_LANG_CODE_KOREAN:					//	HANGUL			ÇŃ±Ű 
; 2557 : 	case I3_LANG_CODE_JAPANESE:					//	SHIFTJIS		ŔĎş»ľî
; 2558 : 	case I3_LANG_CODE_CHINESE_SIMPLIFIED:		//	GB2312			Áß±ąľî °ŁĂĽ
; 2559 : 	case I3_LANG_CODE_CHINESE_TRADITIONAL:		//	CHINESEBIG5		Áß±ąľî ąřĂĽ
; 2560 : 		{
; 2561 : #if I3_WINDOWS
; 2562 : 			return ::CharNextExA((WORD) nCodePage, pszStr, 0);
; 2563 : #else
; 2564 : 			//	CJK(ÇŃÁßŔĎ) ľđľî´Â DBCS ˝Ă˝şĹŰ (2ąŮŔĚĆ®) 
; 2565 : 			if( *pszStr & 0x80)		//	lead byte		ascii żµżŞŔş 0 ~ 127(0x7E) ŔĚ¸ç 0x80 şÎĹÍ ±Řµż ľđľî(DBCS)·Î ŔÎ˝ÄµČ´Ů.
; 2566 : 			{
; 2567 : 				pszStr++;
; 2568 : 			}
; 2569 : 
; 2570 : 			return (*pszStr != 0 ? pszStr++ : pszStr);
; 2571 : #endif
; 2572 : 		}
; 2573 : 		break;
; 2574 : 	default:
; 2575 : 		{
; 2576 : #if I3_WINDOWS
; 2577 : 			return ::CharNextExA((WORD) nCodePage, pszStr, 0);
; 2578 : #else
; 2579 : 			return pszStr++;		//	ÄÚµĺ ĆäŔĚÁö°ˇ Á¤ŔÇµÇÁö ľĘľŇ´Ů.
; 2580 : #endif
; 2581 : 		}
; 2582 : 		break;
; 2583 : 	}
; 2584 : }
