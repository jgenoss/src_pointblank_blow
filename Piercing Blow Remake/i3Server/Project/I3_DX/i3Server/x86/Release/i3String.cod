; 2493 : 				I3ASSERT( prev_class >= 0 && prev_class < 17);
; 2494 : 
; 2495 : 				THAI_CLASS curr_class = THAI_CLASS_TABLE[curr_stream];
; 2496 : 				I3ASSERT( curr_class >= 0 && curr_class < 17);
; 2497 : 
; 2498 : 				THAI_INPUT_TYPE state_type = THAI_INPUT_STATE_CHECK[prev_class][curr_class];
; 2499 : 
; 2500 : 				return THAI_INPUT_COMPOSIBLE[mode][state_type];
; 2501 : 			}
; 2502 : 		}
; 2503 : 		break;
; 2504 : 	default:
; 2505 : 		I3ASSERT_0;
; 2506 : 		break;
; 2507 : 	}
; 2508 : 
; 2509 : 	return FALSE;
; 2510 : }
