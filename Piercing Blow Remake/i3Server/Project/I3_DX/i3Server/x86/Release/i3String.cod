; 2000 : I3_EXPORT_BASE 
; 2001 : void	i3String::PreprocessMacro( char * pszDest, INT32 Length, const char * pszSrc, I3_SYMBOLTABLE_INFO * pTable, INT32 symbolCount)
; 2002 : {
; 2003 : 	char * pszTemp = (char *) pszSrc;
; 2004 : 	char szSym[65];
; 2005 : 	INT32 symAccm = 0;
; 2006 : 	bool bInSymbol = false;
; 2007 : 	I3_SYMBOLTABLE_INFO * pSymbol;
; 2008 : 
; 2009 : 	while( *pszTemp != 0)
; 2010 : 	{
; 2011 : 		switch( *pszTemp)
; 2012 : 		{
; 2013 : 			case '%' :
; 2014 : 				if( bInSymbol)
; 2015 : 				{
; 2016 : 					if( symAccm == 0)
; 2017 : 					{
; 2018 : 						// %% ŔÇ °ćżě
; 2019 : 						*pszDest = '%';
; 2020 : 						pszDest++;
; 2021 : 					}
; 2022 : 					else
; 2023 : 					{
; 2024 : 						szSym[ symAccm] = 0;
; 2025 : 						symAccm = 0;
; 2026 : 
; 2027 : 						pSymbol = _FindSymbol( pTable, symbolCount, szSym);
; 2028 : 
; 2029 : 						if( pSymbol != NULL)
; 2030 : 						{
; 2031 : 							INT32 len = (INT32)strlen( pSymbol->m_szValue);
; 2032 : 
; 2033 : 							memcpy( pszDest, pSymbol->m_szValue, len);
; 2034 : 							pszDest += len;
; 2035 : 						}
; 2036 : 						else
; 2037 : 						{
; 2038 : 							I3TRACE( "żĂąŮ¸ŁÁö ľĘŔş Symbol : %s\n", szSym);
; 2039 : 						}
; 2040 : 					}
; 2041 : 
; 2042 : 					bInSymbol = false;
; 2043 : 				}
; 2044 : 				else
; 2045 : 				{
; 2046 : 					bInSymbol = true;
; 2047 : 					symAccm = 0;
; 2048 : 				}
; 2049 : 				break;
; 2050 : 
; 2051 : 			default :
; 2052 : 				if( bInSymbol)
; 2053 : 				{
; 2054 : 					szSym[ symAccm ] = *pszTemp;
; 2055 : 					symAccm ++;
; 2056 : 				}
; 2057 : 				else
; 2058 : 				{
; 2059 : 					*pszDest = *pszTemp;
; 2060 : 					pszDest++;
; 2061 : 				}
; 2062 : 				break;
; 2063 : 		}
; 2064 : 
; 2065 : 		pszTemp++;
; 2066 : 	}
; 2067 : 
; 2068 : 	*pszDest = 0;
; 2069 : }
; 2070 : 
; 2071 : bool _scanWildcard( char * pszName, char * pszRull)
; 2072 : {
; 2073 : 	while( (*pszRull != 0) && (*pszName != 0))
; 2074 : 	{
; 2075 : 		switch( *pszRull)
; 2076 : 		{
; 2077 : 			case '*' :			return true;
; 2078 : 
; 2079 : 			case '?' :
; 2080 : 				break;
; 2081 : 
; 2082 : 			default :
; 2083 : 				if( toupper( *pszName) != toupper( *pszRull))
; 2084 : 					return false;
; 2085 : 				break;
; 2086 : 		}
; 2087 : 
; 2088 : 		pszRull++;
; 2089 : 		pszName++;
; 2090 : 	}
; 2091 : 
; 2092 : 	if( *pszRull != *pszName)
; 2093 : 		return false;
; 2094 : 
; 2095 : 	return true;
; 2096 : }
; 2097 : 
; 2098 : I3_EXPORT_BASE
; 2099 : bool i3String::IsMatchedWildcard( char * pszFileName, char * pszRull)
; 2100 : {
; 2101 : 	char	szRullName[ MAX_PATH], szRullExt[ MAX_PATH];
; 2102 : 	char	szName[ MAX_PATH], szExt[ MAX_PATH];
; 2103 : 
; 2104 : 	i3String::SplitFileName( pszRull, szRullName, FALSE);
; 2105 : 	i3String::SplitFileExt( pszRull, szRullExt, sizeof(szRullExt));
; 2106 : 
; 2107 : 	i3String::SplitFileName( pszFileName, szName, FALSE);
; 2108 : 	i3String::SplitFileExt(	 pszFileName, szExt, sizeof(szExt) - 1);
; 2109 : 
; 2110 : 	if( szRullName[0] != 0)
; 2111 : 	{
; 2112 : 		if( _scanWildcard( szName, szRullName) == false)
; 2113 : 			return false;
; 2114 : 	}
; 2115 : 
; 2116 : 	if( szRullExt[0] != 0)
; 2117 : 	{
; 2118 : 		if( _scanWildcard( szExt, szRullExt) == false)
; 2119 : 			return false;
; 2120 : 	}
; 2121 : 
; 2122 : 	return true;
; 2123 : }
