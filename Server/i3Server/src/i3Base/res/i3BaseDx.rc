IDD_UNEXPECTION DIALOGEX 0, 0, 320, 168
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "오류보고"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "오류 보고 보냄",IDC_B_SEND,106,144,68,16
    CONTROL         107,IDC_STATIC,"Static",SS_BITMAP | SS_REALSIZEIMAGE | SS_SUNKEN,7,7,33,31
    LTEXT           "프로그램에 문제가 있어서 프로그램을 종료해야 합니다.\n\n불편을 끼쳐드려서 죄송합니다.\n\n\n제페토(주)에 보낼 수 있는 오류 보고를 작성했습니다.\n\n이 내용은 기밀로 간주되며 익명으로 관리합니다.\n\n\n보내주신 오류보고는 저희에게 큰 힘이 됩니다.\n\n\n제페토(주)에 오류 보고에 대한 메일을 보내시겠습니까 ?",IDC_STATIC,84,14,216,116
    PUSHBUTTON      "보내지 않음",IDOK,245,144,68,16
END


