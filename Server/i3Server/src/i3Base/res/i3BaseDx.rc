IDD_LOGPOPUP DIALOGEX 0, 0, 344, 90
STYLE DS_SYSMODAL | DS_SETFONT | DS_MODALFRAME | DS_3DLOOK | DS_FIXEDSYS | DS_NOFAILCREATE | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_TOOLWINDOW
CAPTION "i3Engine Event Log"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "Break",IDOK,117,73,50,14
    PUSHBUTTON      "Continue",IDCANCEL,171,73,50,14
    CONTROL         107,IDC_STATIC,"Static",SS_BITMAP | SS_REALSIZEIMAGE | SS_SUNKEN,5,5,33,31
    LTEXT           "Where",IDC_STATIC,54,5,22,8
    EDITTEXT        IDC_ED_WHERE,80,3,261,12,ES_AUTOHSCROLL | ES_READONLY | NOT WS_BORDER,WS_EX_STATICEDGE
    LTEXT           "Message",IDC_STATIC,48,18,29,8
    EDITTEXT        IDC_ED_MSG,80,18,261,20,ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | NOT WS_BORDER | WS_VSCROLL,WS_EX_STATICEDGE
    LTEXT           "System",IDC_STATIC,52,41,24,8
    EDITTEXT        IDC_ED_SYS,80,40,261,31,ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | NOT WS_BORDER | WS_VSCROLL,WS_EX_STATICEDGE
    PUSHBUTTON      "More...",IDC_BUTTON1,291,73,50,14,WS_DISABLED
