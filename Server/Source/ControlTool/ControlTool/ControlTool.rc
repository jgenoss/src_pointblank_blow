        BEGIN
            MENUITEM "All Disable",                 ID_CHECKHACKING_DISABLE
            POPUP "Dll Cheat"
            BEGIN
                MENUITEM "0 %",                         ID_DLLCHEAT_0
                MENUITEM "10 %",                        ID_DLLCHEAT_10
