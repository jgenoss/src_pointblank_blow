IDR_MENU_POP MENU
BEGIN
    POPUP "pop"
    BEGIN
        MENUITEM "Connect Control Server",      ID_POP_CONNECT_CONTROL
        MENUITEM "Start Server",                ID_POP_STARTSERVER
        MENUITEM "Stop Server",                 ID_POP_STOPSERVER
        MENUITEM "User Kick",                   ID_POP_USERKICK
        MENUITEM "Trans User Kick",             ID_POP_TRANSUSERKICK
        MENUITEM "Warning Clear",               ID_POP_WARNINGCLEAR
        MENUITEM "Not Allow Room Creation",     ID_POP_NOTALLOWROOMCREATION
