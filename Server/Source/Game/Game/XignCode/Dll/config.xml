			<info>true</info>
			<error>true</error>
			<stats>true</stats>
			<interval>1</interval>
		</log>	
		<filter>
			<z_rtn_black_code>Z_RTN_NONE</z_rtn_black_code>
			<z_rtn_suspicious>Z_RTN_NONE</z_rtn_suspicious>
		</filter>

		<timeout>
			<max>1</max>
			<quantum>110</quantum>
			<ban>true</ban>
		</timeout>
		<zce>
			<enable>true</enable>
			<cnt>4</cnt>
			<quantum>120</quantum>
		</zce>
		<ncb>
			<enable>true</enable>
			<cnt>1</cnt>
			<quantum>120</quantum>
		</ncb>
		<resend>
			<max>5</max>
			<ban>true</ban>
		</resend>
